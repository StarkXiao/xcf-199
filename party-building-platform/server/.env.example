# MySQL 数据库连接配置
# 复制此文件为 .env 并根据实际环境修改

# 数据库类型：mysql 或 json（默认 mysql）
DB_TYPE=mysql

# MySQL 连接配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=party_building

# JWT 密钥（生产环境请修改为复杂随机字符串）
JWT_SECRET=party-building-platform-secret-key-change-in-production

# 服务端口（默认 3000）
PORT=3000
